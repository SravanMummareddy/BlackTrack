# ============================================================
# Environment Variables — [PROJECT_NAME]
# ============================================================
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local — it's in .gitignore.
#
# Safe to commit:  NODE_ENV, PORT, LOG_LEVEL, NEXT_PUBLIC_* vars
# NEVER commit:    Secrets, passwords, API keys, database credentials
# ============================================================

# --- Application ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# --- Database ---
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Generate password: openssl rand -base64 24
DATABASE_URL=postgresql://postgres:[PASSWORD]@localhost:5432/[PROJECT_NAME]_dev

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Authentication ---
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=[GENERATE_RANDOM_64_BYTE_HEX]
JWT_REFRESH_SECRET=[GENERATE_RANDOM_64_BYTE_HEX]

# --- OAuth (optional) ---
# Google: console.cloud.google.com
GOOGLE_CLIENT_ID=[YOUR_GOOGLE_CLIENT_ID]
GOOGLE_CLIENT_SECRET=[YOUR_GOOGLE_CLIENT_SECRET]

# GitHub: github.com/settings/applications/new
GITHUB_CLIENT_ID=[YOUR_GITHUB_CLIENT_ID]
GITHUB_CLIENT_SECRET=[YOUR_GITHUB_CLIENT_SECRET]

# Callback URL — update for each environment
OAUTH_CALLBACK_URL=http://localhost:3000/api/v1/auth/oauth/callback

# --- Frontend ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Connection Pool (optional, defaults are used if not set) ---
# DB_POOL_MAX=10
